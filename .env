# Your Google Gemini API Key from Google AI Studio
GOOGLE_API_KEY=your_actual_gemini_api_key_here

# Base URL pointing to the Flask mock server we just created
MOCK_SERVER_URL=http://127.0.0.1:5001

# Optional frontend backend callback URL for RCA updates
FRONTEND_BACKEND_URL=
# Optional bearer token for frontend backend callback
FRONTEND_BACKEND_AUTH=
